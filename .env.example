# Shared deployment variables for docker compose.
TZ=Asia/Shanghai
BACKEND_PORT=8000
FRONTEND_PORT=8001
KEYCLOAK_PORT=8090

# Browser-facing URLs.
KEYCLOAK_EXTERNAL_URL=http://localhost:8090
VITE_KEYCLOAK_URL=http://localhost:8090
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HOSTNAME_STRICT_HTTPS=false

# Keycloak realm and clients.
KEYCLOAK_REALM=ai-testcase
KEYCLOAK_BACKEND_CLIENT_ID=backend
VITE_KEYCLOAK_REALM=ai-testcase
VITE_KEYCLOAK_CLIENT_ID=frontend
VITE_KEYCLOAK_BACKEND_CLIENT_ID=backend
VITE_KEYCLOAK_PKCE_METHOD=S256

# Backend-internal Keycloak/admin access.
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_SYNC_STRICT=false
KEYCLOAK_SYNC_RETRIES=6
KEYCLOAK_SYNC_RETRY_DELAY=5

# Database.
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_password

# Comma-separated browser origins allowed to call the backend.
CORS_ORIGINS=http://localhost:5173,http://localhost:8001
