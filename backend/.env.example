# Keycloak 认证配置
# 内部网络地址（Docker 内用 http://keycloak:8080，本地用 http://localhost:8080）
KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_EXTERNAL_URL: 外部访问地址（浏览器看到的地址，用于验证 JWT issuer）
KEYCLOAK_EXTERNAL_URL=http://192.168.13.111:8080
KEYCLOAK_REALM=ai-testcase
KEYCLOAK_CLIENT_ID=backend

# CORS 允许的前端域名（多个用逗号分隔）
CORS_ORIGINS=http://192.168.13.111:5173,http://192.168.13.111:8001

# 时区
TZ=Asia/Shanghai
