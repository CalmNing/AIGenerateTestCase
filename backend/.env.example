# Keycloak authentication config.
# Local backend runs usually use http://localhost:8090; Docker compose injects http://keycloak:8080.
KEYCLOAK_SERVER_URL=http://localhost:8090
# Must match the browser-facing Keycloak URL and JWT issuer.
KEYCLOAK_EXTERNAL_URL=http://localhost:8090
KEYCLOAK_REALM=ai-testcase
KEYCLOAK_CLIENT_ID=backend

# Keycloak admin API config.
KEYCLOAK_ADMIN_URL=http://localhost:8090
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_SYNC_STRICT=false
KEYCLOAK_SYNC_RETRIES=6
KEYCLOAK_SYNC_RETRY_DELAY=5

# Comma-separated browser origins allowed to call the backend.
CORS_ORIGINS=http://localhost:5173,http://localhost:8001

# Timezone.
TZ=Asia/Shanghai
